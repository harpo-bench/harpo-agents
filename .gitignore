# Python
__pycache__/
*.py[cod]
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.env
.venv
venv/
env/
*.log

# OS
.DS_Store
.idea/
.vscode/

# HARPO run artifacts (root-level — generated by benchmarks, not committed)
harpo_*.json
harpo_*.txt
harpo_*.dot
*.html
evolution_diff_*.html
index*.html

# Sample outputs in benchmarks/ ARE committed (tracked explicitly)
!benchmarks/*/sample_output/*.json
!benchmarks/*/sample_output/*.txt
!benchmarks/*/sample_output/*.dot

# Test fixtures ARE committed
!tests/fixtures/*.json
